{
  "manifest_version": 3,
  "name": "Versatile",
  "version": "1.0",
  "description": "Unified task management and productivity dashboard for Canvas.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://canvas.vt.edu/*",
    "*://*.instructure.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["*://canvas.vt.edu/*", "*://*.instructure.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "*://canvas.vt.edu/*", 
        "*://*.instructure.com/*"
      ],
      "css": ["styles.css"],
      "js": [
        "storage.js",
        "dateUtils.js",
        "utils.js",
        "canvasApi.js",
        "notifications.js",
        "tasks.js",
        "taskHandlers.js",
        "courseDetail.js",
        "sidebar.js",
        "init.js"
      ]
    }
  ]
}